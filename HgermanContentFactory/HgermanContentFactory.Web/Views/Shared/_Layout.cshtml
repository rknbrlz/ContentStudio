<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Hgerman Content Factory</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

<!-- Sidebar -->
<div class="d-flex">
    <nav class="sidebar d-flex flex-column flex-shrink-0 p-3">
        <a href="/" class="brand-link mb-4 text-decoration-none">
            <span class="brand-icon">H</span>
            <span class="brand-text">Content<br><strong>Factory</strong></span>
        </a>

        <ul class="nav nav-pills flex-column gap-1">
            <li><a class="nav-link @ActiveClass("Dashboard")" asp-controller="Dashboard" asp-action="Index">
                <i class="bi bi-speedometer2"></i> Dashboard</a></li>
            <li><a class="nav-link @ActiveClass("Channels")" asp-controller="Channels" asp-action="Index">
                <i class="bi bi-collection-play"></i> Channels</a></li>
            <li><a class="nav-link @ActiveClass("Videos")" asp-controller="Videos" asp-action="Index">
                <i class="bi bi-camera-video"></i> Videos</a></li>
            <li><a class="nav-link @ActiveClass("Campaigns")" asp-controller="Campaigns" asp-action="Index">
                <i class="bi bi-megaphone"></i> Campaigns</a></li>
            <li><a class="nav-link @ActiveClass("Trends")" asp-controller="Trends" asp-action="Index">
                <i class="bi bi-graph-up-arrow"></i> Trends</a></li>
            <li class="mt-3 border-top pt-3">
            <a class="nav-link @ActiveClass("Settings")" asp-controller="Settings" asp-action="Index">
                <i class="bi bi-gear"></i> Settings</a></li>
            <li><a class="nav-link" href="/hangfire" target="_blank">
                <i class="bi bi-clock-history"></i> Scheduler</a></li>
        </ul>

        <div class="sidebar-footer mt-auto pt-3 border-top">
            <small class="text-muted">
                <i class="bi bi-circle-fill text-success" style="font-size:.6rem"></i>
                System Running
            </small>
        </div>
    </nav>

    <!-- Main content -->
    <main class="main-content flex-grow-1">
        <div class="topbar d-flex align-items-center justify-content-between px-4 py-2">
            <h6 class="mb-0 text-muted fw-normal">@(ViewData["Title"] ?? "Dashboard")</h6>
            <div class="d-flex gap-3 align-items-center">
                <span class="badge bg-primary">
                    <i class="bi bi-translate me-1"></i>
                    EN · DE · ES · FR · IT · PL
                </span>
                <span class="badge bg-secondary">
                    <i class="bi bi-youtube me-1"></i>YouTube API
                </span>
            </div>
        </div>

        <div class="p-4">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>

@functions {
    string ActiveClass(string controller) =>
        ViewContext.RouteData.Values["controller"]?.ToString() == controller ? "active" : "";
}
