@model IReadOnlyList<VideoJobListItemDto>
@{
    ViewData["Title"] = "Video Jobs";
}

@if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success shadow-sm border-0" role="alert">
        @successMessage
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <h5 class="mb-0">All Jobs</h5>

            <div class="d-flex gap-2">
                <form asp-action="RunAutomationNow" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">⚡ Run Auto Now</button>
                </form>

                <a asp-action="Create" class="btn btn-dark">New Job</a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Job No</th>
                        <th>Title</th>
                        <th>Language</th>
                        <th>Platform</th>
                        <th>Status</th>
                        <th>Step</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.JobNo</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.JobNo) && item.JobNo.StartsWith("AUTO-"))
                                {
                                    <span class="badge rounded-pill text-bg-success me-2">AUTO</span>
                                }

                                @if (item.IsPublished)
                                {
                                    <span class="badge rounded-pill text-bg-primary me-2">PUBLISHED</span>
                                }

                                @item.Title
                            </td>
                            <td>@item.LanguageCode</td>
                            <td>@item.PlatformType</td>
                            <td>
                                <span class="badge text-bg-secondary">@item.Status</span>
                            </td>
                            <td>@item.CurrentStep</td>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.VideoJobId" class="btn btn-sm btn-outline-dark">
                                    Open
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>