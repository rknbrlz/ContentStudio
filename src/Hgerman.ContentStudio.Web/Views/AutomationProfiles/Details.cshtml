@model Hgerman.ContentStudio.Domain.Entities.VideoJob

@{
    ViewData["Title"] = $"Video Job #{Model.VideoJobId}";
    var orderedScenes = Model.Scenes?.OrderBy(x => x.SceneNo).ToList()
        ?? new List<Hgerman.ContentStudio.Domain.Entities.VideoScene>();

    var orderedAssets = Model.Assets?.OrderByDescending(x => x.AssetId).ToList()
        ?? new List<Hgerman.ContentStudio.Domain.Entities.Asset>();

    var finalVideoAsset = orderedAssets
        .FirstOrDefault(x =>
            !string.IsNullOrWhiteSpace(x.FileName) &&
            x.FileName.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase));

    string progressBarClass = Model.Status.ToString() switch
    {
        "Completed" => "bg-success",
        "Failed" => "bg-danger",
        _ => "bg-primary"
    };
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">Video Job #@Model.VideoJobId</h1>
            <div class="text-muted">@Model.Title</div>
        </div>

        <div class="text-end">
            <div><strong>Status:</strong> @Model.Status</div>
            <div><strong>Step:</strong> @Model.CurrentStep</div>
            <div><strong>Progress:</strong> @Model.ProgressPercent%</div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="progress" style="height:22px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated @progressBarClass"
                     role="progressbar"
                     style="width:@Model.ProgressPercent%;"
                     aria-valuenow="@Model.ProgressPercent"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    @Model.ProgressPercent%
                </div>
            </div>

            <div class="mt-2 text-muted small">
                Last update: @(Model.UpdatedDate.HasValue
                                ? Model.UpdatedDate.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                : "-")
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <strong>Overview</strong>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Job No</div>
                        <div class="col-sm-8">@Model.JobNo</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Profile</div>
                        <div class="col-sm-8">
                            @if (Model.AutomationProfileId.HasValue && Model.AutomationProfile != null)
                            {
                                <a asp-controller="AutomationProfiles"
                                   asp-action="Details"
                                   asp-route-id="@Model.AutomationProfileId.Value"
                                   class="badge text-bg-primary text-decoration-none">
                                    @Model.AutomationProfile.Name
                                </a>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Manual</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Origin</div>
                        <div class="col-sm-8">
                            @if (Model.AutomationProfileId.HasValue)
                            {
                                <span class="badge text-bg-success">Automation</span>
                            }
                            else
                            {
                                <span class="badge text-bg-secondary">Manual</span>
                            }
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Language</div>
                        <div class="col-sm-8">@Model.LanguageCode</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Platform</div>
                        <div class="col-sm-8">@Model.PlatformType</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Tone</div>
                        <div class="col-sm-8">@Model.ToneType</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Duration Target</div>
                        <div class="col-sm-8">@Model.DurationTargetSec sec</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Scenes</div>
                        <div class="col-sm-8">@orderedScenes.Count</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Assets</div>
                        <div class="col-sm-8">@orderedAssets.Count</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Subtitle</div>
                        <div class="col-sm-8">@(Model.SubtitleEnabled ? "Enabled" : "Disabled")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Published</div>
                        <div class="col-sm-8">@(Model.IsPublished ? "Yes" : "No")</div>
                    </div>

                    @if (finalVideoAsset != null)
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-semibold">Output File</div>
                            <div class="col-sm-8">@finalVideoAsset.FileName</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.Topic))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-semibold">Topic</div>
                            <div class="col-sm-8">@Model.Topic</div>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.PublishedUrl))
                    {
                        <div class="row mb-2">
                            <div class="col-sm-4 fw-semibold">Published Url</div>
                            <div class="col-sm-8 text-break">
                                <a href="@Model.PublishedUrl" target="_blank">@Model.PublishedUrl</a>
                            </div>
                        </div>
                    }

                    <div class="row mb-2">
                        <div class="col-sm-4 fw-semibold">Created</div>
                        <div class="col-sm-8">@Model.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</div>
                    </div>

                    <div class="row mb-0">
                        <div class="col-sm-4 fw-semibold">Updated</div>
                        <div class="col-sm-8">
                            @(Model.UpdatedDate.HasValue
                                                        ? Model.UpdatedDate.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                                        : "-")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <strong>Source</strong>
                </div>
                <div class="card-body">
                    @if (Model.PrimarySourceAsset != null)
                    {
                        <div class="mb-2">
                            <strong>Primary Source:</strong> @Model.PrimarySourceAsset.FileName
                        </div>

                        <div class="text-muted small text-break">
                            @Model.PrimarySourceAsset.BlobPath
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">No source asset.</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(Model.SourcePrompt))
                    {
                        <hr />
                        <div class="fw-semibold mb-2">Source Prompt</div>
                        <div class="small" style="white-space:pre-wrap;">@Model.SourcePrompt</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <strong>Scenes</strong>
        </div>
        <div class="card-body p-0">
            @if (orderedScenes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:70px;">#</th>
                                <th>Text</th>
                                <th>Prompt</th>
                                <th style="width:120px;">Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var scene in orderedScenes)
                            {
                                <tr>
                                    <td>@scene.SceneNo</td>
                                    <td style="white-space:pre-wrap;">@scene.SceneText</td>
                                    <td style="white-space:pre-wrap;">@scene.ScenePrompt</td>
                                    <td>@scene.DurationSecond</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No scenes found.</div>
            }
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">
            <strong>Assets</strong>
        </div>
        <div class="card-body p-0">
            @if (orderedAssets.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>File Name</th>
                                <th>Type</th>
                                <th>Mime Type</th>
                                <th>Blob Path</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var asset in orderedAssets)
                            {
                                <tr>
                                    <td>@asset.AssetId</td>
                                    <td>@asset.FileName</td>
                                    <td>@asset.AssetType</td>
                                    <td>@asset.MimeType</td>
                                    <td class="text-break">@asset.BlobPath</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No assets found.</div>
            }
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong>Error Logs</strong>
        </div>
        <div class="card-body p-0">
            @if (Model.ErrorLogs != null && Model.ErrorLogs.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Step</th>
                                <th>Type</th>
                                <th>Message</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var error in Model.ErrorLogs.OrderByDescending(x => x.CreatedDate))
                            {
                                <tr>
                                    <td>@error.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@error.StepName</td>
                                    <td>@error.ErrorType</td>
                                    <td style="white-space:pre-wrap;">@error.ErrorMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No errors.</div>
            }
        </div>
    </div>
</div>