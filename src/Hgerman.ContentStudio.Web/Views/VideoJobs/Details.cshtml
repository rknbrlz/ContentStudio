@using Hgerman.ContentStudio.Domain.Enums
@using Hgerman.ContentStudio.Domain.Entities
@model VideoJob

@{
    ViewData["Title"] = "Video Job Details";
    var orderedScenes = Model.Scenes.OrderBy(x => x.SceneNo).ToList();
    var orderedAssets = Model.Assets.OrderBy(x => x.AssetType).ThenBy(x => x.AssetId).ToList();
    var orderedErrors = Model.ErrorLogs.OrderByDescending(x => x.ErrorLogId).ToList();
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
        <div>
            <h2 class="mb-1">Video Job #@Model.VideoJobId</h2>
            <div class="text-muted">@Model.Title</div>
        </div>
        <div class="text-end">
            <div><strong>Status:</strong> <span id="job-status">@Model.Status</span></div>
            <div><strong>Step:</strong> <span id="job-step">@Model.CurrentStep</span></div>
            <div><strong>Progress:</strong> <span id="job-progress-text">@Model.ProgressPercent%</span></div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <div class="progress" style="height: 22px;">
                <div id="job-progress-bar"
                     class="progress-bar progress-bar-striped progress-bar-animated"
                     role="progressbar"
                     style="width:@Model.ProgressPercent%">
                    @Model.ProgressPercent%
                </div>
            </div>
            <div class="small text-muted mt-2">
                Last update: <span id="job-updated-date">@(Model.UpdatedDate.HasValue? Model.UpdatedDate.Value.ToString("yyyy-MM-dd HH:mm:ss") : "-")</span>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><strong>Overview</strong></div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Job No</dt>
                        <dd class="col-sm-8">@Model.JobNo</dd>

                        <dt class="col-sm-4">Language</dt>
                        <dd class="col-sm-8">@Model.LanguageCode</dd>

                        <dt class="col-sm-4">Platform</dt>
                        <dd class="col-sm-8">@Model.PlatformType</dd>

                        <dt class="col-sm-4">Duration</dt>
                        <dd class="col-sm-8">@Model.DurationTargetSec sec</dd>

                        <dt class="col-sm-4">Scenes</dt>
                        <dd class="col-sm-8"><span id="job-scene-count">@orderedScenes.Count</span></dd>

                        <dt class="col-sm-4">Assets</dt>
                        <dd class="col-sm-8"><span id="job-asset-count">@orderedAssets.Count</span></dd>

                        <dt class="col-sm-4">Errors</dt>
                        <dd class="col-sm-8"><span id="job-error-count">@orderedErrors.Count</span></dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card h-100">
                <div class="card-header"><strong>Source</strong></div>
                <div class="card-body">
                    @if (Model.PrimarySourceAsset != null)
                    {
                        <div><strong>File:</strong> @Model.PrimarySourceAsset.FileName</div>
                        <div><strong>Mime:</strong> @Model.PrimarySourceAsset.MimeType</div>
                        <div class="text-break"><strong>Blob Path:</strong> @Model.PrimarySourceAsset.BlobPath</div>
                    }
                    else
                    {
                        <div class="text-muted">No source asset.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header"><strong>Scenes</strong></div>
        <div class="card-body p-0">
            @if (orderedScenes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Text</th>
                                <th>Prompt</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var scene in orderedScenes)
                            {
                                <tr>
                                    <td>@scene.SceneNo</td>
                                    <td>@scene.SceneText</td>
                                    <td>@scene.ScenePrompt</td>
                                    <td>@scene.DurationSecond</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No scenes generated yet.</div>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header"><strong>Assets</strong></div>
        <div class="card-body">
            @if (orderedAssets.Any())
            {
                <ul class="mb-0">
                    @foreach (var asset in orderedAssets)
                    {
                        <li class="mb-2">
                            <strong>@asset.AssetType</strong> - @asset.FileName
                            <div class="small text-muted">@asset.BlobPath</div>
                            <div class="small">@asset.Status</div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">No assets yet.</div>
            }
        </div>
    </div>

    <div class="card mt-4">
        <div class="card-header"><strong>Errors</strong></div>
        <div class="card-body">
            @if (orderedErrors.Any())
            {
                @foreach (var err in orderedErrors)
                {
                    <div class="border rounded p-2 mb-2">
                        <div><strong>@err.StepName</strong> - @err.ErrorType</div>
                        <div class="small text-muted">@err.CreatedDate.ToString("yyyy-MM-dd HH:mm")</div>
                        <div>@err.ErrorMessage</div>
                    </div>
                }
            }
            else
            {
                <div class="text-muted">No errors logged.</div>
            }
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        (function () {
            const jobId = @Model.VideoJobId;
            let lastSceneCount = @orderedScenes.Count;
            let lastAssetCount = @orderedAssets.Count;
            let lastErrorCount = @orderedErrors.Count;
            let stopped = false;

            async function poll() {
                if (stopped) return;

                try {
                    const response = await fetch('@Url.Action("Status", "VideoJobs", new { id = Model.VideoJobId })', {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    });

                    if (!response.ok) return;

                    const data = await response.json();

                    document.getElementById('job-status').textContent = data.status;
                    document.getElementById('job-step').textContent = data.currentStep;
                    document.getElementById('job-progress-text').textContent = `${data.progressPercent}%`;
                    document.getElementById('job-updated-date').textContent = data.updatedDate;
                    document.getElementById('job-scene-count').textContent = data.sceneCount;
                    document.getElementById('job-asset-count').textContent = data.assetCount;
                    document.getElementById('job-error-count').textContent = data.errorCount;

                    const bar = document.getElementById('job-progress-bar');
                    bar.style.width = `${data.progressPercent}%`;
                    bar.textContent = `${data.progressPercent}%`;
                    bar.setAttribute('aria-valuenow', data.progressPercent);

                    const countChanged =
                        data.sceneCount !== lastSceneCount ||
                        data.assetCount !== lastAssetCount ||
                        data.errorCount !== lastErrorCount;

                    if (countChanged) {
                        location.reload();
                        return;
                    }

                    if (data.isTerminal) {
                        stopped = true;
                        if (data.status === 'Completed') {
                            bar.classList.remove('progress-bar-animated');
                            bar.classList.remove('progress-bar-striped');
                        }
                    }
                } catch (e) {
                    console.error(e);
                }
            }

            poll();
            setInterval(poll, 4000);
        })();
    </script>
}