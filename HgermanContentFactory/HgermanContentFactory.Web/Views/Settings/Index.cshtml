@{ ViewData["Title"] = "Settings"; }

<h4 class="fw-bold mb-4">Settings</h4>

<div class="row g-4">
    <!-- API Keys -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-key-fill me-2 text-warning"></i>API Keys</div>
            <div class="card-body">
                <form asp-action="SaveApiKey" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Provider</label>
                        <select name="Provider" class="form-select">
                            <option value="OpenAI">OpenAI (Script Generation)</option>
                            <option value="ElevenLabs">ElevenLabs (Text-to-Speech)</option>
                            <option value="Stability">Stability AI (Thumbnails)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Key Name</label>
                        <input name="KeyName" class="form-control" placeholder="e.g. Production Key" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">API Key</label>
                        <input name="ApiKey" type="password" class="form-control" placeholder="sk-..." />
                    </div>
                    <div class="form-check mb-3">
                        <input name="IsDefault" type="checkbox" class="form-check-input" />
                        <label class="form-check-label">Set as default for this provider</label>
                    </div>
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-save me-2"></i>Save Key
                    </button>
                </form>

                @if (ViewBag.ApiKeys != null && ((IEnumerable<HgermanContentFactory.Core.DTOs.ApiKeyDto>)ViewBag.ApiKeys).Any())
                {
                    <hr />
                    <h6 class="text-muted mb-3">Saved Keys</h6>
                    @foreach (var k in (IEnumerable<HgermanContentFactory.Core.DTOs.ApiKeyDto>)ViewBag.ApiKeys)
                    {
                        <div class="d-flex align-items-center justify-content-between py-2 border-bottom">
                            <div>
                                <span class="badge bg-secondary me-2">@k.Provider</span>
                                <span class="small">@k.KeyName</span>
                                @if (k.IsDefault) { <span class="badge bg-success ms-1">default</span> }
                            </div>
                            <form asp-action="DeleteApiKey" asp-route-id="@k.Id" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-xs btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Schedule Settings -->
    <div class="col-xl-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-clock-history me-2 text-info"></i>Publishing Schedules</div>
            <div class="card-body">
                @if (ViewBag.Schedules != null)
                {
                    @foreach (var s in (IEnumerable<HgermanContentFactory.Core.Entities.CF_Schedule>)ViewBag.Schedules)
                    {
                        <div class="card mb-3" id="sched_@s.Id">
                            <div class="card-body py-3">
                                <h6 class="fw-bold mb-2">@s.Channel.Name</h6>
                                <div class="mb-2">
                                    <label class="form-label small mb-1">
                                        Videos/Day: <strong id="vpdLabel_@s.Id">@s.VideosPerDay</strong>
                                    </label>
                                    <input type="range" class="form-range form-range-sm" min="1" max="20"
                                           value="@s.VideosPerDay"
                                           oninput="document.getElementById('vpdLabel_@s.Id').textContent = this.value"
                                           onchange="updateSchedule(@s.Id, this.value)">
                                </div>
                                <div class="d-flex gap-3 text-muted small">
                                    @if (s.LastRun.HasValue)
                                    {
                                        <span><i class="bi bi-check-circle text-success me-1"></i>Last: @s.LastRun.Value.ToString("MM/dd HH:mm")</span>
                                    }
                                    @if (s.NextRun.HasValue)
                                    {
                                        <span><i class="bi bi-clock me-1"></i>Next: @s.NextRun.Value.ToString("MM/dd HH:mm")</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <!-- YouTube OAuth Info -->
        <div class="card mt-4">
            <div class="card-header"><i class="bi bi-youtube me-2 text-danger"></i>YouTube Configuration</div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    To connect channels to YouTube, you need a Google Cloud OAuth 2.0 Client ID.
                </p>
                <ol class="small text-muted">
                    <li>Go to <strong>console.cloud.google.com</strong></li>
                    <li>Create a project → Enable YouTube Data API v3</li>
                    <li>Create OAuth 2.0 credentials (Web Application)</li>
                    <li>Add <code>https://yourdomain/Channels/YouTubeCallback</code> to redirect URIs</li>
                    <li>Set <code>YouTube:ClientId</code> and <code>YouTube:ClientSecret</code> in <code>appsettings.json</code></li>
                </ol>
                <a href="https://console.cloud.google.com" target="_blank" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-box-arrow-up-right me-1"></i>Open Google Console
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
async function updateSchedule(scheduleId, videosPerDay) {
    const res  = await fetch('/Settings/UpdateSchedule', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ scheduleId, videosPerDay: parseInt(videosPerDay), publishTimes: ['09:00'] })
    });
    const data = await res.json();
    if (data.success) showToast(`Schedule updated: ${data.videosPerDay} videos/day`, 'success');
}
</script>
}
