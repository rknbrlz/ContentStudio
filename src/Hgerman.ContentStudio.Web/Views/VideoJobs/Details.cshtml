@model VideoJob
@using Hgerman.ContentStudio.Domain.Entities
@using Hgerman.ContentStudio.Domain.Enums

@{
    ViewData["Title"] = "Video Job Details";

    var orderedScenes = Model.Scenes?.OrderBy(x => x.SceneNo).ToList() ?? new List<VideoScene>();
    var orderedAssets = Model.Assets?.OrderBy(x => x.AssetType).ThenBy(x => x.AssetId).ToList() ?? new List<Asset>();
    var orderedErrors = Model.ErrorLogs?.OrderByDescending(x => x.ErrorLogId).ToList() ?? new List<ErrorLog>();

    var finalVideoAsset = orderedAssets
        .Where(x => x.AssetType == AssetType.FinalVideo)
        .OrderByDescending(x => x.AssetId)
        .FirstOrDefault();

    string statusBadgeClass = Model.Status switch
    {
        VideoJobStatus.Completed => "bg-success-subtle text-success border border-success-subtle",
        VideoJobStatus.Failed => "bg-danger-subtle text-danger border border-danger-subtle",
        VideoJobStatus.Processing => "bg-warning-subtle text-warning border border-warning-subtle",
        VideoJobStatus.Queued => "bg-secondary-subtle text-secondary border border-secondary-subtle",
        _ => "bg-light text-dark border"
    };

    string progressBarClass = Model.Status switch
    {
        VideoJobStatus.Completed => "bg-success",
        VideoJobStatus.Failed => "bg-danger",
        _ => "bg-dark"
    };
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
    <div>
        <h2 class="mb-1">Video Job Details</h2>
        <div class="text-muted small">
            Job No: <strong>@Model.JobNo</strong>
            <span class="mx-2">•</span>
            ID: <strong>@Model.VideoJobId</strong>
            <span class="mx-2">•</span>
            Updated: <strong id="updatedText">@($"{Model.UpdatedDate:yyyy-MM-dd HH:mm}")</strong>
        </div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a href="/VideoJobs" class="btn btn-outline-secondary">Back to List</a>

        @if (Model.Status == VideoJobStatus.Failed)
        {
            <form asp-action="Retry" asp-route-id="@Model.VideoJobId" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-dark">Retry Job</button>
            </form>
        }

        <button type="button"
                id="publishYoutubeTopBtn"
                class="btn btn-danger @(finalVideoAsset == null ? "d-none" : "")"
                onclick="publishToYouTube(@Model.VideoJobId)">
            Publish to YouTube
        </button>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-3">
            <div>
                <h5 class="mb-1">@Model.Title</h5>
                <div class="small text-muted">
                    @Model.PlatformType • @Model.LanguageCode • @Model.DurationTargetSec sec • @Model.ToneType
                </div>
            </div>
            <div>
                <span id="statusBadge" class="badge rounded-pill px-3 py-2 @statusBadgeClass">@Model.Status</span>
            </div>
        </div>

        <div class="mb-2 d-flex justify-content-between small">
            <span>Current Step: <strong data-step id="currentStepText">@Model.CurrentStep</strong></span>
            <span><strong data-progress id="progressText">@Model.ProgressPercent%</strong></span>
        </div>

        <div class="progress" style="height:10px;">
            <div id="progressBar"
                 class="progress-bar @progressBarClass"
                 role="progressbar"
                 style="width:@Model.ProgressPercent%;"
                 aria-valuenow="@Model.ProgressPercent"
                 aria-valuemin="0"
                 aria-valuemax="100">
            </div>
        </div>

        <div id="errorMessageContainer" class="@(string.IsNullOrWhiteSpace(Model.ErrorMessage) ? "d-none" : "")">
            <div class="alert alert-danger mt-3 mb-0">
                <strong>Error:</strong>
                <span id="errorMessageText">@Model.ErrorMessage</span>
            </div>
        </div>
    </div>
</div>

@if (Model.PrimarySourceAsset != null)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="mb-3">Source Image</h5>

            <div class="row g-3 align-items-start">
                <div class="col-lg-3">
                    @if (!string.IsNullOrWhiteSpace(Model.PrimarySourceAsset.PublicUrl))
                    {
                        <img src="@Model.PrimarySourceAsset.PublicUrl"
                             alt="Source Image"
                             class="img-fluid rounded border" />
                    }
                    else
                    {
                        <div class="border rounded d-flex align-items-center justify-content-center text-muted bg-light"
                             style="height:180px;">
                            No preview
                        </div>
                    }
                </div>

                <div class="col-lg-9">
                    <p class="text-muted mb-3">
                        This video job was created from an uploaded image.
                    </p>

                    <dl class="row small mb-0">
                        <dt class="col-sm-3">File</dt>
                        <dd class="col-sm-9">@Model.PrimarySourceAsset.FileName</dd>

                        <dt class="col-sm-3">Mime</dt>
                        <dd class="col-sm-9">@Model.PrimarySourceAsset.MimeType</dd>

                        <dt class="col-sm-3">Blob Path</dt>
                        <dd class="col-sm-9 text-break">@Model.PrimarySourceAsset.BlobPath</dd>

                        @if (!string.IsNullOrWhiteSpace(Model.PrimarySourceAsset.PublicUrl))
                        {
                            <dt class="col-sm-3">Preview</dt>
                            <dd class="col-sm-9">
                                <a href="@Model.PrimarySourceAsset.PublicUrl" target="_blank" rel="noopener">
                                    Open source image
                                </a>
                            </dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100 mb-4">
            <div class="card-body">
                <h5 class="mb-3">Overview</h5>

                <dl class="row small mb-0">
                    <dt class="col-5">Job No</dt>
                    <dd class="col-7">@Model.JobNo</dd>

                    <dt class="col-5">Title</dt>
                    <dd class="col-7">@Model.Title</dd>

                    <dt class="col-5">Status</dt>
                    <dd class="col-7"><span id="overviewStatus">@Model.Status</span></dd>

                    <dt class="col-5">Step</dt>
                    <dd class="col-7"><span id="overviewStep">@Model.CurrentStep</span></dd>

                    <dt class="col-5">Language</dt>
                    <dd class="col-7">@Model.LanguageCode</dd>

                    <dt class="col-5">Platform</dt>
                    <dd class="col-7">@Model.PlatformType</dd>

                    <dt class="col-5">Tone</dt>
                    <dd class="col-7">@Model.ToneType</dd>

                    <dt class="col-5">Aspect</dt>
                    <dd class="col-7">@Model.AspectRatio</dd>

                    <dt class="col-5">Duration</dt>
                    <dd class="col-7">@Model.DurationTargetSec sec</dd>

                    <dt class="col-5">Retry Count</dt>
                    <dd class="col-7">@Model.RetryCount</dd>

                    <dt class="col-5">Created</dt>
                    <dd class="col-7">@($"{Model.CreatedDate:yyyy-MM-dd HH:mm}")</dd>

                    <dt class="col-5">Completed</dt>
                    <dd class="col-7"><span id="completedDateText">@(Model.CompletedDate != null ? $"{Model.CompletedDate:yyyy-MM-dd HH:mm}" : "-")</span></dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="mb-3">Publish Panel</h5>

                <div id="publishReadyBox" class="@(finalVideoAsset == null ? "d-none" : "")">
                    <div class="alert alert-success small">
                        Final video is ready for publishing.
                    </div>

                    <div class="d-grid gap-2">
                        <button type="button"
                                id="publishYoutubePanelBtn"
                                class="btn btn-danger"
                                onclick="publishToYouTube(@Model.VideoJobId)">
                            Publish to YouTube
                        </button>

                        <a id="openFinalVideoBtn"
                           class="btn btn-outline-dark @(finalVideoAsset?.PublicUrl == null ? "d-none" : "")"
                           href="@finalVideoAsset?.PublicUrl"
                           target="_blank"
                           rel="noopener">
                            Open Final Video
                        </a>
                    </div>
                </div>

                <div id="publishNotReadyBox" class="@(finalVideoAsset == null ? "" : "d-none")">
                    <p class="text-muted mb-0">
                        Final video is not ready yet. Publish button will be available after rendering completes.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div id="finalVideoCard" class="card shadow-sm border-0 mb-4 @(finalVideoAsset == null ? "d-none" : "")">
            <div class="card-body">
                <h5 class="mb-3">Final Video</h5>

                <div id="finalVideoPlayerWrap" class="@(finalVideoAsset?.PublicUrl == null ? "d-none" : "")">
                    <video id="finalVideoPlayer" controls class="w-100 rounded border" style="max-height:720px;">
                        @if (!string.IsNullOrWhiteSpace(finalVideoAsset?.PublicUrl))
                        {
                            <source src="@finalVideoAsset.PublicUrl" type="video/mp4" />
                        }
                    </video>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <a id="finalVideoOpenNewTabBtn"
                           href="@finalVideoAsset?.PublicUrl"
                           target="_blank"
                           rel="noopener"
                           class="btn btn-outline-dark btn-sm @(finalVideoAsset?.PublicUrl == null ? "d-none" : "")">
                            Open in New Tab
                        </a>

                        <button type="button"
                                id="finalVideoPublishBtn"
                                class="btn btn-danger btn-sm"
                                onclick="publishToYouTube(@Model.VideoJobId)">
                            Publish to YouTube
                        </button>
                    </div>
                </div>

                <div id="finalVideoEmptyBox" class="@(finalVideoAsset?.PublicUrl == null ? "" : "d-none")">
                    <div class="alert alert-warning mb-0">
                        Final video asset exists but PublicUrl is empty.
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Scenes</h5>
                    <span id="sceneCountBadge" class="badge bg-light text-dark border">@orderedScenes.Count</span>
                </div>

                @if (orderedScenes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th style="width:70px;">#</th>
                                    <th>Text</th>
                                    <th>Prompt</th>
                                    <th style="width:110px;">Duration</th>
                                </tr>
                            </thead>
                            <tbody id="sceneTableBody">
                                @foreach (var scene in orderedScenes)
                                {
                                    <tr>
                                        <td class="fw-semibold">@scene.SceneNo</td>
                                        <td style="min-width:220px;">@scene.SceneText</td>
                                        <td class="text-muted small" style="min-width:260px;">@scene.ScenePrompt</td>
                                        <td>@scene.DurationSecond</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div id="sceneEmptyMessage" class="d-none">
                        <p class="text-muted mb-0">No scenes generated yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive d-none">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th style="width:70px;">#</th>
                                    <th>Text</th>
                                    <th>Prompt</th>
                                    <th style="width:110px;">Duration</th>
                                </tr>
                            </thead>
                            <tbody id="sceneTableBody"></tbody>
                        </table>
                    </div>

                    <div id="sceneEmptyMessage">
                        <p class="text-muted mb-0">No scenes generated yet.</p>
                    </div>
                }
            </div>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Assets</h5>
                    <span id="assetCountBadge" class="badge bg-light text-dark border">@orderedAssets.Count</span>
                </div>

                <div id="assetList">
                    @if (orderedAssets.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var asset in orderedAssets)
                            {
                                var isFinal = asset.AssetType == AssetType.FinalVideo;

                                <div class="list-group-item px-0 py-3">
                                    <div class="d-flex justify-content-between align-items-start gap-3">
                                        <div class="flex-grow-1">
                                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                                <span class="fw-semibold">@asset.AssetType</span>

                                                @if (isFinal)
                                                {
                                                    <span class="badge bg-success">Final</span>
                                                }

                                                <span class="small text-muted">@asset.Status</span>
                                            </div>

                                            <div class="small mb-1">
                                                <strong>File:</strong> @asset.FileName
                                            </div>

                                            <div class="small text-muted text-break">
                                                @asset.BlobPath
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(asset.PublicUrl))
                                            {
                                                <div class="mt-2">
                                                    <a href="@asset.PublicUrl" target="_blank" rel="noopener" class="small">
                                                        Open asset
                                                    </a>
                                                </div>
                                            }
                                        </div>

                                        <div class="text-end small text-muted" style="min-width:90px;">
                                            @if (asset.FileSize != null)
                                            {
                                                <div>@asset.FileSize bytes</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No assets yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Errors</h5>
                    <span id="errorCountBadge" class="badge bg-light text-dark border">@orderedErrors.Count</span>
                </div>

                <div id="errorList">
                    @if (orderedErrors.Any())
                    {
                        @foreach (var err in orderedErrors)
                        {
                            <div class="border rounded p-3 mb-2">
                                <div class="fw-semibold">@err.StepName - @err.ErrorType</div>
                                <div class="small text-muted mb-2">@($"{err.CreatedDate:yyyy-MM-dd HH:mm}")</div>
                                <div class="small text-break">@err.ErrorMessage</div>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No errors logged.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const jobId = @Model.VideoJobId;
    let pollHandle = null;

    function getStatusBadgeClass(status) {
        switch (status) {
            case "Completed":
                return "badge rounded-pill px-3 py-2 bg-success-subtle text-success border border-success-subtle";
            case "Failed":
                return "badge rounded-pill px-3 py-2 bg-danger-subtle text-danger border border-danger-subtle";
            case "Processing":
                return "badge rounded-pill px-3 py-2 bg-warning-subtle text-warning border border-warning-subtle";
            case "Queued":
                return "badge rounded-pill px-3 py-2 bg-secondary-subtle text-secondary border border-secondary-subtle";
            default:
                return "badge rounded-pill px-3 py-2 bg-light text-dark border";
        }
    }

    function getProgressBarClass(status) {
        switch (status) {
            case "Completed":
                return "progress-bar bg-success";
            case "Failed":
                return "progress-bar bg-danger";
            default:
                return "progress-bar bg-dark";
        }
    }

    function escapeHtml(value) {
        if (value === null || value === undefined) return "";
        return String(value)
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }

    function renderScenes(scenes) {
        const sceneTableBody = document.getElementById("sceneTableBody");
        const sceneCountBadge = document.getElementById("sceneCountBadge");
        const sceneEmptyMessage = document.getElementById("sceneEmptyMessage");
        const tableWrap = sceneTableBody.closest(".table-responsive");

        sceneCountBadge.textContent = scenes.length;

        if (!scenes || scenes.length === 0) {
            sceneTableBody.innerHTML = "";
            if (tableWrap) tableWrap.classList.add("d-none");
            if (sceneEmptyMessage) sceneEmptyMessage.classList.remove("d-none");
            return;
        }

        if (tableWrap) tableWrap.classList.remove("d-none");
        if (sceneEmptyMessage) sceneEmptyMessage.classList.add("d-none");

        let html = "";
        scenes.forEach(scene => {
            html += `
                <tr>
                    <td class="fw-semibold">${escapeHtml(scene.sceneNo)}</td>
                    <td style="min-width:220px;">${escapeHtml(scene.sceneText)}</td>
                    <td class="text-muted small" style="min-width:260px;">${escapeHtml(scene.scenePrompt)}</td>
                    <td>${escapeHtml(scene.durationSecond)}</td>
                </tr>
            `;
        });

        sceneTableBody.innerHTML = html;
    }

    function renderAssets(assets) {
        const assetList = document.getElementById("assetList");
        const assetCountBadge = document.getElementById("assetCountBadge");

        assetCountBadge.textContent = assets.length;

        if (!assets || assets.length === 0) {
            assetList.innerHTML = `<p class="text-muted mb-0">No assets yet.</p>`;
            return;
        }

        let html = `<div class="list-group list-group-flush">`;

        assets.forEach(asset => {
            const isFinal = asset.assetType === "FinalVideo";

            html += `
                <div class="list-group-item px-0 py-3">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="flex-grow-1">
                            <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                <span class="fw-semibold">${escapeHtml(asset.assetType)}</span>
                                ${isFinal ? `<span class="badge bg-success">Final</span>` : ``}
                                <span class="small text-muted">${escapeHtml(asset.status)}</span>
                            </div>

                            <div class="small mb-1">
                                <strong>File:</strong> ${escapeHtml(asset.fileName)}
                            </div>

                            <div class="small text-muted text-break">
                                ${escapeHtml(asset.blobPath)}
                            </div>

                            ${asset.publicUrl
                                ? `<div class="mt-2"><a href="${escapeHtml(asset.publicUrl)}" target="_blank" rel="noopener" class="small">Open asset</a></div>`
                                : ``}
                        </div>

                        <div class="text-end small text-muted" style="min-width:90px;">
                            ${asset.fileSize !== null && asset.fileSize !== undefined ? `<div>${escapeHtml(asset.fileSize)} bytes</div>` : ``}
                        </div>
                    </div>
                </div>
            `;
        });

        html += `</div>`;
        assetList.innerHTML = html;
    }

    function renderErrors(errors) {
        const errorList = document.getElementById("errorList");
        const errorCountBadge = document.getElementById("errorCountBadge");

        errorCountBadge.textContent = errors.length;

        if (!errors || errors.length === 0) {
            errorList.innerHTML = `<p class="text-muted mb-0">No errors logged.</p>`;
            return;
        }

        let html = "";
        errors.forEach(err => {
            html += `
                <div class="border rounded p-3 mb-2">
                    <div class="fw-semibold">${escapeHtml(err.stepName)} - ${escapeHtml(err.errorType)}</div>
                    <div class="small text-muted mb-2">${escapeHtml(err.createdDate)}</div>
                    <div class="small text-break">${escapeHtml(err.errorMessage)}</div>
                </div>
            `;
        });

        errorList.innerHTML = html;
    }

    function updateFinalVideo(finalVideo) {
        const finalVideoCard = document.getElementById("finalVideoCard");
        const finalVideoPlayerWrap = document.getElementById("finalVideoPlayerWrap");
        const finalVideoEmptyBox = document.getElementById("finalVideoEmptyBox");
        const publishReadyBox = document.getElementById("publishReadyBox");
        const publishNotReadyBox = document.getElementById("publishNotReadyBox");
        const publishYoutubeTopBtn = document.getElementById("publishYoutubeTopBtn");
        const openFinalVideoBtn = document.getElementById("openFinalVideoBtn");
        const finalVideoOpenNewTabBtn = document.getElementById("finalVideoOpenNewTabBtn");
        const finalVideoPlayer = document.getElementById("finalVideoPlayer");

        if (!finalVideo) {
            finalVideoCard.classList.add("d-none");
            publishReadyBox.classList.add("d-none");
            publishNotReadyBox.classList.remove("d-none");
            publishYoutubeTopBtn.classList.add("d-none");
            return;
        }

        finalVideoCard.classList.remove("d-none");
        publishReadyBox.classList.remove("d-none");
        publishNotReadyBox.classList.add("d-none");
        publishYoutubeTopBtn.classList.remove("d-none");

        if (finalVideo.publicUrl) {
            finalVideoPlayerWrap.classList.remove("d-none");
            finalVideoEmptyBox.classList.add("d-none");

            finalVideoPlayer.innerHTML = `<source src="${escapeHtml(finalVideo.publicUrl)}" type="video/mp4" />`;
            finalVideoPlayer.load();

            openFinalVideoBtn.href = finalVideo.publicUrl;
            openFinalVideoBtn.classList.remove("d-none");

            finalVideoOpenNewTabBtn.href = finalVideo.publicUrl;
            finalVideoOpenNewTabBtn.classList.remove("d-none");
        } else {
            finalVideoPlayerWrap.classList.add("d-none");
            finalVideoEmptyBox.classList.remove("d-none");
            openFinalVideoBtn.classList.add("d-none");
            finalVideoOpenNewTabBtn.classList.add("d-none");
        }
    }

    function updateMainStatus(data) {
        const statusBadge = document.getElementById("statusBadge");
        const currentStepText = document.getElementById("currentStepText");
        const progressText = document.getElementById("progressText");
        const progressBar = document.getElementById("progressBar");
        const overviewStatus = document.getElementById("overviewStatus");
        const overviewStep = document.getElementById("overviewStep");
        const updatedText = document.getElementById("updatedText");
        const completedDateText = document.getElementById("completedDateText");
        const errorMessageContainer = document.getElementById("errorMessageContainer");
        const errorMessageText = document.getElementById("errorMessageText");

        statusBadge.className = getStatusBadgeClass(data.status);
        statusBadge.textContent = data.status;

        currentStepText.textContent = data.step;
        overviewStatus.textContent = data.status;
        overviewStep.textContent = data.step;

        progressText.textContent = `${data.progress}%`;
        progressBar.className = getProgressBarClass(data.status);
        progressBar.style.width = `${data.progress}%`;
        progressBar.setAttribute("aria-valuenow", data.progress);

        updatedText.textContent = data.updated || "-";
        completedDateText.textContent = data.completedDate || "-";

        if (data.errorMessage) {
            errorMessageContainer.classList.remove("d-none");
            errorMessageText.textContent = data.errorMessage;
        } else {
            errorMessageContainer.classList.add("d-none");
            errorMessageText.textContent = "";
        }
    }

    async function refreshJob() {
        try {
            const response = await fetch(`/VideoJobs/GetStatus?id=${jobId}`, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                console.error("Status request failed:", response.status);
                return;
            }

            const data = await response.json();

            updateMainStatus(data);
            renderScenes(data.scenes || []);
            renderAssets(data.assets || []);
            renderErrors(data.errors || []);
            updateFinalVideo(data.finalVideo);

            if (data.status === "Completed" || data.status === "Failed") {
                stopPolling();
            }
        } catch (error) {
            console.error("Refresh error", error);
        }
    }

    function startPolling() {
        if (pollHandle) return;
        pollHandle = setInterval(refreshJob, 4000);
    }

    function stopPolling() {
        if (!pollHandle) return;
        clearInterval(pollHandle);
        pollHandle = null;
    }

    async function publishToYouTube(videoJobId) {
        const ok = confirm("Bu videoyu YouTube'a yüklemek istiyor musun?");
        if (!ok) return;

        try {
            const response = await fetch(`/VideoJobs/PublishToYouTube/${videoJobId}`, {
                method: 'POST'
            });

            const result = await response.json();

            if (result.success) {
                alert("Upload tamamlandı: " + result.youtubeUrl);
                window.open(result.youtubeUrl, "_blank");
            } else {
                alert("Hata: " + (result.error || "Bilinmeyen hata"));
            }
        } catch (error) {
            alert("İstek sırasında hata oluştu.");
            console.error(error);
        }
    }

    document.addEventListener("DOMContentLoaded", function () {
        const initialStatus = "@Model.Status";
        if (initialStatus !== "Completed" && initialStatus !== "Failed") {
            startPolling();
        }
    });
</script>