@model IReadOnlyList<Hgerman.ContentStudio.Domain.Entities.AutomationProfile>

@{
    ViewData["Title"] = "Automation Profiles";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">Automation Profiles</h1>
            <div class="text-muted">Create, edit and run content automation profiles.</div>
        </div>

        <div>
            <a asp-action="Create" class="btn btn-primary">+ New Profile</a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Language</th>
                                <th>Growth</th>
                                <th>Daily Limit</th>
                                <th>Hours</th>
                                <th>Last Run</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.OrderByDescending(x => x.AutomationProfileId))
                            {
                                <tr>
                                    <td>@item.AutomationProfileId</td>
                                    <td>@item.Name</td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge text-bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">Passive</span>
                                        }
                                </td>
                                <td>@item.LanguageCode</td>
                                <td>@item.GrowthMode</td>
                                <td>@item.DailyVideoLimit</td>
                                <td>@item.PreferredHoursCsv</td>
                                <td>
                                    @(item.LastRunAtUtc.HasValue
                                                                    ? item.LastRunAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                                                    : "-")
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Details"
                                       asp-route-id="@item.AutomationProfileId"
                                       class="btn btn-sm btn-outline-dark">
                                        Details
                                    </a>

                                            <a asp-action="Edit"
                                               asp-route-id="@item.AutomationProfileId"
                                               class="btn btn-sm btn-outline-primary">
                                                Edit
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                                                }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No automation profiles found.</div>
            }
        </div>
    </div>
</div>