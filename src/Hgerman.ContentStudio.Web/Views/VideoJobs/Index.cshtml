@model IReadOnlyList<Hgerman.ContentStudio.Shared.DTOs.VideoJobListItemDto>

@{
    ViewData["Title"] = "Video Jobs";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">Video Jobs</h1>
            <div class="text-muted">Manage and monitor generated videos.</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary">
                + New Video Job
            </a>

            <form asp-controller="VideoJobs"
                  asp-action="RunAutomationNow"
                  method="post"
                  class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success">
                    ▶ Run Automation Now
                </button>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Job No</th>
                                <th>Title</th>
                                <th>Profile</th>
                                <th>Platform</th>
                                <th>Language</th>
                                <th>Status</th>
                                <th>Step</th>
                                <th>Published</th>
                                <th>Created</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in Model.OrderByDescending(x => x.VideoJobId))
                            {
                                <tr>
                                    <td>@job.VideoJobId</td>
                                    <td>@job.JobNo</td>
                                    <td class="fw-semibold">@job.Title</td>
                                    <td>@job.ProfileName</td>
                                    <td>@job.PlatformType</td>
                                    <td>@job.LanguageCode</td>
                                    <td>
                                        @{
                                            var badgeClass = job.Status switch
                                            {
                                                "Completed" => "text-bg-success",
                                                "Failed" => "text-bg-danger",
                                                "Processing" => "text-bg-primary",
                                                "Queued" => "text-bg-warning",
                                                _ => "text-bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@job.Status</span>
                                    </td>
                                    <td>@job.Step</td>
                                    <td>
                                        @if (job.IsPublished)
                                        {
                                            <span class="badge text-bg-success">Yes</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-secondary">No</span>
                                        }
                                    </td>
                                    <td>@job.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-action="Details"
                                           asp-route-id="@job.VideoJobId"
                                           class="btn btn-sm btn-outline-dark">
                                            Open
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">
                    No video jobs found.
                </div>
            }
        </div>
    </div>
</div>