@model Hgerman.ContentStudio.Domain.Entities.AutomationProfile

@{
    ViewData["Title"] = $"Automation Profile #{Model.AutomationProfileId}";
    var jobs = Model.VideoJobs?
        .OrderByDescending(x => x.VideoJobId)
        .ToList() ?? new List<Hgerman.ContentStudio.Domain.Entities.VideoJob>();
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@Model.Name</h1>
            <div class="text-muted">Automation profile details and recent generated jobs.</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Edit"
               asp-route-id="@Model.AutomationProfileId"
               class="btn btn-outline-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-outline-secondary">
                Back
            </a>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Profile ID</div>
                    <div class="fs-4 fw-semibold">@Model.AutomationProfileId</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Status</div>
                    <div class="fs-4 fw-semibold">
                        @if (Model.IsActive)
                        {
                            <span class="badge text-bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Passive</span>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Language</div>
                    <div class="fs-4 fw-semibold">@Model.LanguageCode</div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Daily Limit</div>
                    <div class="fs-4 fw-semibold">@Model.DailyVideoLimit</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <strong>Profile Settings</strong>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-5">Project Id</dt>
                        <dd class="col-sm-7">@Model.ProjectId</dd>

                        <dt class="col-sm-5">Platform Type</dt>
                        <dd class="col-sm-7">@Model.PlatformType</dd>

                        <dt class="col-sm-5">Tone Type</dt>
                        <dd class="col-sm-7">@Model.ToneType</dd>

                        <dt class="col-sm-5">Duration Target</dt>
                        <dd class="col-sm-7">@Model.DurationTargetSec sec</dd>

                        <dt class="col-sm-5">Aspect Ratio</dt>
                        <dd class="col-sm-7">@Model.AspectRatio</dd>

                        <dt class="col-sm-5">Subtitle Enabled</dt>
                        <dd class="col-sm-7">@(Model.SubtitleEnabled ? "Yes" : "No")</dd>

                        <dt class="col-sm-5">Thumbnail Enabled</dt>
                        <dd class="col-sm-7">@(Model.ThumbnailEnabled ? "Yes" : "No")</dd>

                        <dt class="col-sm-5">Auto Publish YouTube</dt>
                        <dd class="col-sm-7">@(Model.AutoPublishYouTube ? "Yes" : "No")</dd>

                        <dt class="col-sm-5">Growth Mode</dt>
                        <dd class="col-sm-7">@Model.GrowthMode</dd>

                        <dt class="col-sm-5">Title Test Variants</dt>
                        <dd class="col-sm-7">@Model.TitleTestVariants</dd>

                        <dt class="col-sm-5">Min Success Score</dt>
                        <dd class="col-sm-7">@Model.MinSuccessScore</dd>

                        <dt class="col-sm-5">Preferred Hours</dt>
                        <dd class="col-sm-7">@(!string.IsNullOrWhiteSpace(Model.PreferredHoursCsv) ? Model.PreferredHoursCsv : "-")</dd>

                        <dt class="col-sm-5">Last Run</dt>
                        <dd class="col-sm-7">
                            @(Model.LastRunAtUtc.HasValue
                                                        ? Model.LastRunAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                                        : "-")
                        </dd>

                        <dt class="col-sm-5">Created</dt>
                        <dd class="col-sm-7">
                            @Model.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        </dd>

                        <dt class="col-sm-5">Updated</dt>
                        <dd class="col-sm-7">
                            @(Model.UpdatedDate.HasValue
                                                        ? Model.UpdatedDate.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                                        : "-")
                        </dd>
                    </dl>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm h-100">
                <div class="card-header">
                    <strong>Prompt Configuration</strong>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Topic Prompt</label>
                        <div class="border rounded p-3 bg-light">
                            @(!string.IsNullOrWhiteSpace(Model.TopicPrompt) ? Model.TopicPrompt : "-")
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Hook Template</label>
                        <div class="border rounded p-3 bg-light">
                            @(!string.IsNullOrWhiteSpace(Model.HookTemplate) ? Model.HookTemplate : "-")
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Viral Pattern Template</label>
                        <div class="border rounded p-3 bg-light">
                            @(!string.IsNullOrWhiteSpace(Model.ViralPatternTemplate) ? Model.ViralPatternTemplate : "-")
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Trend Keywords CSV</label>
                        <div class="border rounded p-3 bg-light">
                            @(!string.IsNullOrWhiteSpace(Model.TrendKeywordsCsv) ? Model.TrendKeywordsCsv : "-")
                        </div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-semibold">Seed Topics CSV</label>
                        <div class="border rounded p-3 bg-light">
                            @(!string.IsNullOrWhiteSpace(Model.SeedTopicsCsv) ? Model.SeedTopicsCsv : "-")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Recent Video Jobs</strong>
            <span class="text-muted small">@jobs.Count item(s)</span>
        </div>

        <div class="card-body p-0">
            @if (jobs.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Job ID</th>
                                <th>Title</th>
                                <th>Status</th>
                                <th>Topic</th>
                                <th>Duration</th>
                                <th>Created</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in jobs)
                            {
                                <tr>
                                    <td>@job.VideoJobId</td>
                                    <td class="fw-semibold">@job.Title</td>
                                    <td>
                                        @{
                                            var badgeClass = job.Status.ToString() switch
                                            {
                                                "Completed" => "text-bg-success",
                                                "Failed" => "text-bg-danger",
                                                "Processing" => "text-bg-primary",
                                                "Queued" => "text-bg-warning",
                                                _ => "text-bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@job.Status</span>
                                    </td>
                                    <td>@job.Topic</td>
                                    <td>@job.DurationTargetSec sec</td>
                                    <td>@job.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="text-end">
                                        <a asp-controller="VideoJobs"
                                           asp-action="Details"
                                           asp-route-id="@job.VideoJobId"
                                           class="btn btn-sm btn-outline-dark">
                                            Open
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-3 text-muted">No video jobs found for this automation profile.</div>
            }
        </div>
    </div>
</div>