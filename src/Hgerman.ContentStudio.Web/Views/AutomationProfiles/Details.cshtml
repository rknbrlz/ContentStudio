@model Hgerman.ContentStudio.Shared.DTOs.AutomationProfileDashboardDto

@{
    ViewData["Title"] = "Automation Profile Details";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">@Model.Name</h2>
            <div class="text-muted">Automation analytics dashboard</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.AutomationProfileId" class="btn btn-outline-primary">Edit</a>

            <form asp-action="RunNow" asp-route-id="@Model.AutomationProfileId" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-primary">Run Now</button>
            </form>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Trend Snapshots</div>
                    <div class="display-6">@Model.TrendSnapshotCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Feedback Items</div>
                    <div class="display-6">@Model.FeedbackCount</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="text-muted">Title Performance Rows</div>
                    <div class="display-6">@Model.TitlePerformanceCount</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">Top Trends</div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Keyword</th>
                        <th>Trend Title</th>
                        <th>Score</th>
                        <th>Source</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.TopTrends)
                    {
                        <tr>
                            <td>@item.Keyword</td>
                            <td>@item.TrendTitle</td>
                            <td>@item.TrendScore</td>
                            <td>@item.SourceName</td>
                            <td>@item.SnapshotDateUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header">Recent Feedback</div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Type</th>
                        <th>Signal</th>
                        <th>Score</th>
                        <th>Summary</th>
                        <th>Suggested Action</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.RecentFeedback)
                    {
                        <tr>
                            <td>@item.FeedbackType</td>
                            <td>@item.Signal</td>
                            <td>@(item.ScoreValue?.ToString("F2") ?? "-")</td>
                            <td>@item.Summary</td>
                            <td>@item.SuggestedAction</td>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">Best Title Variants</div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Predicted</th>
                        <th>Actual</th>
                        <th>Winner</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.BestTitles)
                    {
                        <tr>
                            <td>@item.CandidateTitle</td>
                            <td>@item.PredictedScore.ToString("F2")</td>
                            <td>@(item.ActualScore?.ToString("F2") ?? "-")</td>
                            <td>
                                @if (item.IsWinner)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>