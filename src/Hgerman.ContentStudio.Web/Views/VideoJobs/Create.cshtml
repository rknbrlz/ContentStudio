@model Hgerman.ContentStudio.Web.Models.CreateVideoJobViewModel
@using Hgerman.ContentStudio.Domain.Enums

@{
    ViewData["Title"] = "Create Video Job";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">Create Video Job</h1>
            <div class="text-muted">Create and queue a new video generation job.</div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <strong>Job Details</strong>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="ProjectId" class="form-label"></label>
                        <input asp-for="ProjectId" class="form-control" />
                        <span asp-validation-for="ProjectId" class="text-danger"></span>
                    </div>

                    <div class="col-md-9">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Topic" class="form-label"></label>
                        <input asp-for="Topic" class="form-control" />
                        <span asp-validation-for="Topic" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SourcePrompt" class="form-label"></label>
                        <input asp-for="SourcePrompt" class="form-control" />
                        <span asp-validation-for="SourcePrompt" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LanguageCode" class="form-label"></label>
                        <input asp-for="LanguageCode" class="form-control" />
                        <span asp-validation-for="LanguageCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="PlatformType" class="form-label"></label>
                        <select asp-for="PlatformType" class="form-select"
                                asp-items="Html.GetEnumSelectList<PlatformType>()"></select>
                        <span asp-validation-for="PlatformType" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ToneType" class="form-label"></label>
                        <select asp-for="ToneType" class="form-select"
                                asp-items="Html.GetEnumSelectList<ToneType>()"></select>
                        <span asp-validation-for="ToneType" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="AspectRatio" class="form-label"></label>
                        <select asp-for="AspectRatio" class="form-select"
                                asp-items="Html.GetEnumSelectList<AspectRatioType>()"></select>
                        <span asp-validation-for="AspectRatio" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="DurationTargetSec" class="form-label"></label>
                        <input asp-for="DurationTargetSec" class="form-control" />
                        <span asp-validation-for="DurationTargetSec" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="VoiceProvider" class="form-label"></label>
                        <input asp-for="VoiceProvider" class="form-control" />
                        <span asp-validation-for="VoiceProvider" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="VoiceName" class="form-label"></label>
                        <input asp-for="VoiceName" class="form-control" />
                        <span asp-validation-for="VoiceName" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="InputMode" class="form-label"></label>
                        <select asp-for="InputMode" class="form-select"
                                asp-items="Html.GetEnumSelectList<InputModeType>()"></select>
                        <span asp-validation-for="InputMode" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="SourceImage" class="form-label"></label>
                        <input asp-for="SourceImage" type="file" class="form-control" accept="image/*" />
                        <span asp-validation-for="SourceImage" class="text-danger"></span>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="SubtitleEnabled" class="form-check-input" />
                            <label asp-for="SubtitleEnabled" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="ThumbnailEnabled" class="form-check-input" />
                            <label asp-for="ThumbnailEnabled" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create & Queue</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}