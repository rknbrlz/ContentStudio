@using HgermanContentFactory.Core.Entities
@model IEnumerable<CF_Campaign>
@{ ViewData["Title"] = "Campaigns"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0 fw-bold">Campaigns</h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>New Campaign
    </a>
</div>

<div class="row g-3">
@foreach (var c in Model)
{
    var progress = c.TotalVideosPlanned > 0
        ? (int)(c.TotalVideosProduced * 100.0 / c.TotalVideosPlanned)
        : 0;
    var isActive = c.StartDate <= DateTime.UtcNow && (c.EndDate == null || c.EndDate >= DateTime.UtcNow);

    <div class="col-md-6 col-xl-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <h6 class="fw-bold mb-0">@c.Name</h6>
                    <span class="badge @(isActive ? "bg-success" : "bg-secondary")">
                        @(isActive ? "Active" : "Inactive")
                    </span>
                </div>
                <div class="text-muted small mb-3">@c.Channel?.Name</div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between small mb-1">
                        <span>Progress</span>
                        <span>@c.TotalVideosProduced / @c.TotalVideosPlanned videos</span>
                    </div>
                    <div class="progress" style="height:6px">
                        <div class="progress-bar @(progress >= 100 ? "bg-success" : "bg-primary")"
                             style="width:@Math.Min(progress,100)%"></div>
                    </div>
                </div>

                <div class="row g-2 text-center mb-3">
                    <div class="col-4">
                        <div class="fw-bold">@c.VideosPerDay</div>
                        <small class="text-muted">Videos/Day</small>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold">@c.StartDate.ToString("MM/dd")</div>
                        <small class="text-muted">Start</small>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold">@(c.EndDate?.ToString("MM/dd") ?? "∞")</div>
                        <small class="text-muted">End</small>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                        <i class="bi bi-eye me-1"></i>Details
                    </a>
                    <form asp-action="Delete" asp-route-id="@c.Id" method="post"
                          onsubmit="return confirm('Delete campaign?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
@if (!Model.Any())
{
    <div class="col-12 text-center py-5">
        <i class="bi bi-megaphone display-1 text-muted"></i>
        <p class="mt-3 text-muted">No campaigns yet.</p>
        <a asp-action="Create" class="btn btn-primary mt-2">
            <i class="bi bi-plus-lg me-2"></i>Create Campaign
        </a>
    </div>
}
</div>
